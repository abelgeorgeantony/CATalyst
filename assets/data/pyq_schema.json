{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Universal Exam Paper Schema",
  "type": "object",
  "required": [
    "paper_metadata",
    "questions"
  ],
  "properties": {
    "paper_metadata": {
      "type": "object",
      "required": [
        "course_name",
        "test_code",
        "year",
        "total_time",
        "total_questions",
        "maximum_marks",
        "marking_scheme"
      ],
      "properties": {
        "course_name": {
          "type": "string"
        },
        "test_code": {
          "type": "string"
        },
        "year": {
          "type": "integer"
        },
        "total_time": {
          "type": "integer",
          "description": "Total time allowed for the exam in minutes"
        },
        "total_questions": {
          "type": "integer",
          "description": "Total number of questions present in the JSON"
        },
        "maximum_marks": {
          "type": "integer",
          "description": "Calculated as total_questions * reward"
        },
        "marking_scheme": {
          "type": "object",
          "required": [
            "reward",
            "penalty",
            "unanswered"
          ],
          "properties": {
            "reward": {
              "type": "integer"
            },
            "penalty": {
              "type": "integer"
            },
            "unanswered": {
              "type": "integer"
            }
          }
        }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "question_number",
          "question",
          "options",
          "topic_tag",
          "explanation"
        ],
        "properties": {
          "question_number": {
            "type": "integer"
          },
          "question": {
            "type": "object",
            "required": [
              "format"
            ],
            "properties": {
              "direction": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "stem": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "images": {
                "type": [
                  "array",
                  "null"
                ],
                "items": {
                  "type": "string"
                }
              },
              "format": {
                "type": "string",
                "enum": [
                  "shared_passage",
                  "visual_reasoning",
                  "statement_assumption",
                  "course_of_action",
                  "standard_mcq"
                ]
              }
            }
          },
          "options": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "A": {
                "type": "object",
                "properties": {
                  "text": { "type": ["string", "null"] },
                  "image": { "type": ["string", "null"] }
                }
              },
              "B": {
                "type": "object",
                "properties": {
                  "text": { "type": ["string", "null"] },
                  "image": { "type": ["string", "null"] }
                }
              },
              "C": {
                "type": "object",
                "properties": {
                  "text": { "type": ["string", "null"] },
                  "image": { "type": ["string", "null"] }
                }
              },
              "D": {
                "type": "object",
                "properties": {
                  "text": { "type": ["string", "null"] },
                  "image": { "type": ["string", "null"] }
                }
              }
            }
          },
          "correct_answer": {
            "type": [
              "string",
              "null"
            ],
            "enum": ["A", "B", "C", "D", null]
          },
          "topic_tag": {
            "type": "string"
          },
          "explanation": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}